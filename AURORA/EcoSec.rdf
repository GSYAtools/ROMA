    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://gsya.esi.uclm.es/ecosec/ASustainabilityLabel -->

    <NamedIndividual rdf:about="https://gsya.esi.uclm.es/ecosec/ASustainabilityLabel">
        <rdf:type rdf:resource="https://gsya.esi.uclm.es/ecosec/SustainabilityLabel"/>
        <ecosec1:isMoreSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/BSustainabilityLabel"/>
        <rdfs:comment>Represents the highest standard of sustainability. Products or practices with this label are considered to have the lowest environmental impact and highest efficiency and sustainability in their category.</rdfs:comment>
    </NamedIndividual>
    


    <!-- https://gsya.esi.uclm.es/ecosec/BSustainabilityLabel -->

    <NamedIndividual rdf:about="https://gsya.esi.uclm.es/ecosec/BSustainabilityLabel">
        <rdf:type rdf:resource="https://gsya.esi.uclm.es/ecosec/SustainabilityLabel"/>
        <ecosec1:isLessSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/ASustainabilityLabel"/>
        <ecosec1:isMoreSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/CSustainabilityLabel"/>
        <rdfs:comment>Denotes a high level of sustainability, second only to A. Products or practices labeled B are highly sustainable with minor areas for improvement compared to A.</rdfs:comment>
    </NamedIndividual>
    


    <!-- https://gsya.esi.uclm.es/ecosec/CSustainabilityLabel -->

    <NamedIndividual rdf:about="https://gsya.esi.uclm.es/ecosec/CSustainabilityLabel">
        <rdf:type rdf:resource="https://gsya.esi.uclm.es/ecosec/SustainabilityLabel"/>
        <ecosec1:isLessSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/BSustainabilityLabel"/>
        <ecosec1:isMoreSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/DSustainabilityLabel"/>
        <rdfs:comment>Reflects a moderate level of sustainability. C labeled entities offer a balanced sustainability performance but with significant room for improvement to reach higher standards.</rdfs:comment>
    </NamedIndividual>
    


    <!-- https://gsya.esi.uclm.es/ecosec/DSustainabilityLabel -->

    <NamedIndividual rdf:about="https://gsya.esi.uclm.es/ecosec/DSustainabilityLabel">
        <rdf:type rdf:resource="https://gsya.esi.uclm.es/ecosec/SustainabilityLabel"/>
        <ecosec1:isLessSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/CSustainabilityLabel"/>
        <ecosec1:isMoreSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/ESustainabilityLabel"/>
        <rdfs:comment>Indicates a sustainability performance that is below average, with D being more sustainable than E but less so than C, B, and A.</rdfs:comment>
    </NamedIndividual>
    


    <!-- https://gsya.esi.uclm.es/ecosec/ESustainabilityLabel -->

    <NamedIndividual rdf:about="https://gsya.esi.uclm.es/ecosec/ESustainabilityLabel">
        <rdf:type rdf:resource="https://gsya.esi.uclm.es/ecosec/SustainabilityLabel"/>
        <ecosec1:isLessSustainableThan rdf:resource="https://gsya.esi.uclm.es/ecosec/DSustainabilityLabel"/>
        <rdfs:comment>Signifies a lower level of sustainability, indicating a need for significant improvements. Products or practices with an E label have a notable environmental impact and efficiency issues. This label suggests that while some sustainability measures may be in place, there are considerable areas for improvement to move towards a more sustainable outcome.</rdfs:comment>
    </NamedIndividual>
</rdf:RDF>



